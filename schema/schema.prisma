generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  FRESHWATER
  SALTWATER
  ALL_ACCESS
}

enum WaterType {
  SALT
  FRESH
}

enum ScoreLabel {
  POOR
  FAIR
  GOOD
  EXCELLENT
}

enum Confidence {
  LOW
  MEDIUM
  HIGH
}

enum SubscriptionPlan {
  FRESHWATER
  SALTWATER
  ALL_ACCESS
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  PAST_DUE
  TRIALING
}

// ─── Auth Models (Auth.js) ───────────────────────────────

model User {
  id                     String           @id @default(auto()) @map("_id") @db.ObjectId
  email                  String           @unique
  name                   String?
  password               String?
  twoFactorEnabled       Boolean          @default(false)
  twoFactorSecret        String?
  passwordResetToken     String?          @unique
  passwordResetExpiresAt DateTime?
  emailVerified          DateTime?
  image                  String?
  roles                  String[]         @default(["user"])
  subscriptionTier       SubscriptionTier @default(FREE)
  unsubscribeToken       String?          @unique
  subscribedToDigest     Boolean          @default(true)
  subscribedToUpdates    Boolean          @default(true)
  favoriteZoneIds        String[]         @default([])
  pushSubscription       Json?
  notifyHighScore        Boolean          @default(true)
  notifyBiteWindow       Boolean          @default(true)
  highScoreThreshold     Int              @default(80)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
  catchReports CatchReport[]

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Domain Models ───────────────────────────────────────

model Zone {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String    @unique
  waterType     WaterType
  lat           Float
  lon           Float
  radiusMiles   Float
  tideStationId String?
  ndbcBuoyId    String?
  species       String[]
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  forecasts    Forecast[]
  catchReports CatchReport[]

  @@map("zones")
}

model Forecast {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  zoneId        String     @db.ObjectId
  date          DateTime
  score         Int
  label         ScoreLabel
  confidence    Confidence
  biteWindows   Json[]
  conditions    Json
  captainCall   String?
  speciesScores Json[]
  rawData       Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, date])
  @@map("forecasts")
}

model CatchReport {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  zoneId     String   @db.ObjectId
  species    String
  location   Json
  caughtAt   DateTime
  lure       String?
  weight     Float?
  photoUrl   String?
  notes      String?
  isVerified Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("catch_reports")
}

model Lead {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  email                  String   @unique
  source                 String   @default("landing_page")
  subscribedToNewsletter Boolean  @default(true)
  unsubscribeToken       String?  @unique
  createdAt              DateTime @default(now())

  @@map("leads")
}

model Subscription {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  userId               String             @unique @db.ObjectId
  stripeCustomerId     String?
  stripePaymentId      String?
  stripeSubscriptionId String?
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
