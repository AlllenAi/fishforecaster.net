generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  FRESHWATER
  SALTWATER
  ALL_ACCESS
}

enum WaterType {
  SALT
  FRESH
}

enum ScoreLabel {
  POOR
  FAIR
  GOOD
  EXCELLENT
}

enum Confidence {
  LOW
  MEDIUM
  HIGH
}

enum PostStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionPlan {
  FRESHWATER
  SALTWATER
  ALL_ACCESS
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELED
  PAST_DUE
  TRIALING
}

// ─── Auth Models (Auth.js) ───────────────────────────────

model User {
  id                     String           @id @default(auto()) @map("_id") @db.ObjectId
  email                  String           @unique
  name                   String?
  password               String?
  twoFactorEnabled       Boolean          @default(false)
  twoFactorSecret        String?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  emailVerified          DateTime?
  image                  String?
  roles                  String[]         @default(["user"])
  subscriptionTier       SubscriptionTier @default(FREE)
  unsubscribeToken       String?          @unique
  subscribedToDigest     Boolean          @default(true)
  subscribedToUpdates    Boolean          @default(true)
  favoriteZoneIds        String[]         @default([])
  pushSubscription       Json?
  notifyHighScore        Boolean          @default(true)
  notifyBiteWindow       Boolean          @default(true)
  highScoreThreshold     Int              @default(80)
  trialEndsAt            DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  accounts          Account[]
  sessions          Session[]
  subscription      Subscription?
  catchReports      CatchReport[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityLikes    CommunityLike[]
  communityEvents   CommunityEvent[]
  eventRsvps        EventRSVP[]

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Domain Models ───────────────────────────────────────

model Zone {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  slug          String    @unique
  waterType     WaterType
  lat           Float
  lon           Float
  radiusMiles   Float
  tideStationId String?
  ndbcBuoyId    String?
  species       String[]
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  forecasts    Forecast[]
  catchReports CatchReport[]

  @@map("zones")
}

model Forecast {
  id            String     @id @default(auto()) @map("_id") @db.ObjectId
  zoneId        String     @db.ObjectId
  date          DateTime
  score         Int
  label         ScoreLabel
  confidence    Confidence
  biteWindows   Json[]
  conditions    Json
  captainCall   String?
  speciesScores Json[]
  rawData       Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, date])
  @@map("forecasts")
}

model CatchReport {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  zoneId     String   @db.ObjectId
  species    String
  location   Json
  caughtAt   DateTime
  lure       String?
  weight     Float?
  photoUrl   String?
  notes      String?
  isVerified Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@map("catch_reports")
}

model Lead {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  email                  String   @unique
  source                 String   @default("landing_page")
  subscribedToNewsletter Boolean  @default(true)
  unsubscribeToken       String?  @unique
  createdAt              DateTime @default(now())

  @@map("leads")
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId    String   @db.ObjectId
  actorEmail String
  action     String   // e.g. "user.role.update", "report.verify"
  targetType String   // e.g. "user", "catchReport"
  targetId   String   // ID of the affected record
  details    Json?    // Additional context (e.g. { oldRoles, newRoles })
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Subscription {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  userId               String             @unique @db.ObjectId
  stripeCustomerId     String?
  stripePaymentId      String?
  stripeSubscriptionId String?
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Consent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  type      String   // "terms" | "privacy" | "cookies"
  version   String   // e.g. "1.0"
  granted   Boolean  @default(true)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@map("consents")
}

enum RSVPStatus {
  GOING
  INTERESTED
}

// ─── Community Models ────────────────────────────────────

model CommunityEvent {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  userId      String     @db.ObjectId
  title       String
  description String
  photoUrl    String?
  location    String
  eventDate   DateTime
  endDate     DateTime?
  status      PostStatus @default(DRAFT)
  rejectionReason String?
  isDeleted   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  rsvps EventRSVP[]

  @@index([status, eventDate])
  @@index([userId])
  @@map("community_events")
}

model EventRSVP {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String     @db.ObjectId
  userId    String     @db.ObjectId
  status    RSVPStatus
  createdAt DateTime   @default(now())

  event CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_rsvps")
}

model CommunityPost {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  userId          String     @db.ObjectId
  title           String
  story           String
  photoUrls       String[]
  location        String?
  species         String[]
  status          PostStatus @default(DRAFT)
  rejectionReason String?
  isDeleted       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments CommunityComment[]
  likes    CommunityLike[]

  @@index([status, createdAt])
  @@index([userId])
  @@map("community_posts")
}

model CommunityComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String   @db.ObjectId
  userId    String   @db.ObjectId
  text      String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("community_comments")
}

model CommunityLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  postId    String   @db.ObjectId
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("community_likes")
}
