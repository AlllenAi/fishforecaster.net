# ─── Database ─────────────────────────────────────────────
# MongoDB Atlas connection string
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/thefishforecaster

# ─── Authentication (Auth.js v5) ─────────────────────────
AUTH_URL=http://localhost:3000
AUTH_SECRET=your-auth-secret-here

# ─── App URL ──────────────────────────────────────────────
# Must match your deployed domain in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe (One-Time Payments) ───────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
# Use pk_test_ / sk_test_ for development
# Use pk_live_ / sk_live_ for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret from: https://dashboard.stripe.com/webhooks
# Create a webhook pointing to https://yourdomain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from: https://dashboard.stripe.com/products
# You need separate price IDs for test mode vs live mode
STRIPE_FRESHWATER_PRICE_ID=price_...
STRIPE_SALTWATER_PRICE_ID=price_...
STRIPE_ALL_ACCESS_PRICE_ID=price_...

# ─── Email (Resend) ──────────────────────────────────────
# Get key from: https://resend.com/api-keys
EMAIL_API_KEY=re_...
EMAIL_FROM_ADDRESS=forecasts@thefishforecaster.com
EMAIL_FROM_NAME=The Fish Forecaster

# ─── Weather API ─────────────────────────────────────────
# Get key from: https://www.weatherapi.com (free tier available)
WEATHER_API_KEY=your-weatherapi-key

# ─── Push Notifications (VAPID) ─────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ─── Rate Limiting (Upstash Redis) ──────────────────────
# REQUIRED for production (in-memory fallback only works in dev)
# Create a free database at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Cron Jobs ───────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used to secure /api/cron/* endpoints on Vercel
CRON_SECRET=your-cron-secret-here
